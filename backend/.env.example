# Copy to .env and adjust. The skeleton runs with these defaults out of the box.
PORT=3000
HOST=0.0.0.0

# REQUIRED in production — sign JWTs with a long random string.
# Generate one:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=dev-only-insecure-secret-change-me

# Postgres — used once persistence is wired up (Week 2+). The in-memory
# skeleton ignores this, but docker-compose already provides the DB.
DATABASE_URL=postgres://protein:protein@db:5432/protein
